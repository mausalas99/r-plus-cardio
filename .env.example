# Cardionotas / R+ development environment variables (optional — no secrets).
# Copy to .env or export in your shell. Values left empty by default.

# HTTP listen port (Cardionotas default 3838; R+ uses 3738)
# Consumed by: lib/http-port.js, server.js, main.js
# CARDIONOTAS_HTTP_PORT=3838
# R_PLUS_HTTP_PORT=

# UDP LAN beacon bind port (Cardionotas default 3840; R+ uses 3739)
# CARDIONOTAS_BEACON_PORT=3840
# R_PLUS_BEACON_PORT=

# Electron userData path override (main.js sets this at runtime; scripts may read it)
# Consumed by: main.js, server.js, lib/historia-clinica/storage.js, scripts/debug-clinical-unlock.mjs
R_PLUS_USER_DATA=

# LAN host persistence mode rollback (ward IT / support)
# Allowed: legacy | monolith | json | sharded | sql | sql-v3 | sql-monolith | auto (default)
# Consumed by: lan-squad/host-store.js
R_PLUS_LAN_PERSIST_MODE=

# Override team code hash source for LAN auth (dev/tests)
# Consumed by: lan-squad/effective-team-code.js
R_PLUS_LAN_TEAM_CODE=

# Enable second Electron instance as LAN guest peer (npm run dev:lan-peer-app)
# Consumed by: main.js, preload.js
R_PLUS_LAN_PEER=

# Dev peer window: host URL and team code to seed LAN client config
# Consumed by: main.js (lan-dev-peer-seed-config IPC)
R_PLUS_LAN_DEV_PEER_HOST=
R_PLUS_LAN_DEV_PEER_CODE=

# Restore shift PIN for LAN join (default: open / no PIN). Set on host launch only.
# Consumed by: lan-squad/lan-shift-pin-policy.js, preload.js
# R_PLUS_LAN_REQUIRE_SHIFT_PIN=1

# Virtual LAN peer CLI defaults (npm run dev:lan-virtual-peer)
# Consumed by: scripts/lan-virtual-peer.mjs
R_PLUS_LAN_HOST=
R_PLUS_LAN_ROOM=
R_PLUS_LAN_PEER_USER=
R_PLUS_LAN_PEER_NAME=
R_PLUS_LAN_PEER_RANK=
R_PLUS_LAN_PEER_SALA=
R_PLUS_LAN_PATIENT=

# Force @electron/rebuild -f on npm start/posttest (default: skip when ABI matches)
# Consumed by: scripts/rebuild-native-db.mjs
R_PLUS_FORCE_NATIVE_REBUILD=

# Equipos cloud queue (optional — configure in desktop ⇄ → Equipos → Cloudflare)
# Public Worker URL, e.g. https://equipos.example.com
# R_PLUS_EQUIPOS_CLOUD_URL=
# Admin key matching wrangler secret EQUIPOS_ADMIN_KEY (desktop stores in rpc-settings)
# R_PLUS_EQUIPOS_ADMIN_KEY=
# Web Push for equipos waitlist (generate: npx @pushforge/builder vapid)
# EQUIPOS_VAPID_PUBLIC_KEY=
# EQUIPOS_VAPID_PRIVATE_JWK=
